# Copy to server/.env for local development.
NODE_ENV=development
PORT=4000

# Where the SQLite file lives, relative to the server workspace.
DATABASE_URL=./data/maisie.db

# Signing secret for session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-32-byte-random-hex-string

# Origin allowed to call the API with credentials (the Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Seed account passwords (development convenience only).
SEED_ADMIN_PASSWORD=admin1234
SEED_CUSTOMER_PASSWORD=password1234
